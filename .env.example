NODE_ENV=production
LOG_LEVEL=info
TIME_ZONE=Asia/Yekaterinburg

BOT_TOKEN=

# Required for owner-only mode and notifications.
# In private chat OWNER_CHAT_ID and OWNER_USER_ID are usually the same value.
OWNER_CHAT_ID=
OWNER_USER_ID=

TELEGRAM_SOURCE_MODE=web

DATABASE_URL=file:./data/bot.db

# Optional PostHog product analytics.
# When POSTHOG_API_KEY is set, events are also forwarded to PostHog.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Bootstrap list used only on the first start for the current source mode.
# After that, channels are managed in SQLite via /admin.
CHANNELS=job_react,rabotafrontend,findmyremote_frontend

# These numeric values are defaults.
# They can later be overridden at runtime from /admin -> Settings.
CHECK_INTERVAL_SECONDS=300
INITIAL_BACKFILL_DAYS=7
WEEKLY_PAGE_SIZE=5
HEARTBEAT_INTERVAL_SECONDS=15

WEB_PREVIEW_MAX_PAGES_PER_CHANNEL=5
WEB_PREVIEW_CHANNEL_DELAY_MS=1500
WEB_PREVIEW_RETRY_COUNT=2
WEB_PREVIEW_REQUEST_TIMEOUT_MS=10000
WEB_PREVIEW_MAX_RESPONSE_BYTES=1000000
WEB_PREVIEW_MAX_ITEMS_PER_CHANNEL=200

# Owner-only channel discovery. Mention graph and manual batches work without
# MTProto; optional MTProto credentials add Telegram search and recommendations.
CHANNEL_DISCOVERY_MAX_QUERIES=10
CHANNEL_DISCOVERY_QUERY_LIMIT=20
CHANNEL_DISCOVERY_MAX_CANDIDATES=50
CHANNEL_DISCOVERY_SAMPLE_POSTS=30
CHANNEL_DISCOVERY_RECENT_RAW_DAYS=30
CHANNEL_DISCOVERY_REQUEST_DELAY_MS=1000
CHANNEL_DISCOVERY_DUCKDUCKGO_ENABLED=false
CHANNEL_DISCOVERY_DUCKDUCKGO_TIMEOUT_MS=10000
CHANNEL_DISCOVERY_DUCKDUCKGO_MAX_RESPONSE_BYTES=500000

# Safe cleanup of technical history. Vacancies, raw messages, profiles,
# user statuses, active channels and blocked discovery candidates are retained.
TECHNICAL_CLEANUP_ENABLED=true
ANALYTICS_RETENTION_DAYS=90
CHANNEL_DISCOVERY_RUN_RETENTION_DAYS=30
CHANNEL_DISCOVERY_CHECK_RETENTION_DAYS=180

# Automatic local SQLite snapshots under data/runtime/backups.
AUTOMATIC_BACKUP_ENABLED=true
AUTOMATIC_BACKUP_INTERVAL_HOURS=24
AUTOMATIC_BACKUP_RETENTION_DAYS=14

# Optional hh.ru API source. HH_USER_AGENT is required when enabled.
HH_SOURCE_ENABLED=false
HH_USER_AGENT=
HH_ACCESS_TOKEN=
HH_MAX_UNIQUE_QUERIES_PER_CYCLE=10
HH_MAX_ACTIVE_USERS_PER_CYCLE=10
HH_PER_PAGE=20
HH_MAX_PAGES_PER_QUERY=1

# Optional company careers source. Sources are added by owner in /admin.
COMPANY_CAREERS_SOURCE_ENABLED=false
COMPANY_CAREERS_POLL_INTERVAL_SECONDS=21600
COMPANY_CAREERS_MAX_SOURCES_PER_CYCLE=20
COMPANY_CAREERS_REQUEST_TIMEOUT_MS=10000
COMPANY_CAREERS_MAX_RESPONSE_BYTES=1000000
COMPANY_CAREERS_REQUEST_DELAY_MS=1000
COMPANY_CAREERS_USER_AGENT=job-tg-bot/company-careers

# Required for frontend channel discovery and for TELEGRAM_SOURCE_MODE=mtproto.
# Get TELEGRAM_API_ID and TELEGRAM_API_HASH at https://my.telegram.org,
# then run npm run auth:telegram to generate TELEGRAM_SESSION.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
