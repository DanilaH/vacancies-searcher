{
  "name": "job-tg-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram vacancy bot for remote React and TypeScript roles",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "auth:telegram": "tsx src/scripts/auth-telegram.ts",
    "analyze:vacancy-cards": "tsx src/scripts/analyze-vacancy-cards.ts",
    "repair:multi-vacancy-posts": "tsx src/scripts/repair-multi-vacancy-posts.ts",
    "healthcheck": "node dist/healthcheck.js",
    "local:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/run-bot.ps1",
    "local:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/install-task.ps1",
    "local:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/status.ps1",
    "local:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/uninstall-task.ps1",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.1.2",
    "dotenv": "^17.4.2",
    "grammy": "^1.43.0",
    "posthog-node": "^5.13.0",
    "pino": "^10.3.1",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
